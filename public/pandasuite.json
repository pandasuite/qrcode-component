{
  "version": "2.0.0",
  "main": "",

  "system": {
    "localization": false,
    "markers": false
  },

  "properties": [
    {
      "id": "text",
      "name": "Text",
      "locale_name": {
        "fr_FR": "Texte"
      },
      "type": "String",
      "bind": {
        "style": "TextArea",
        "lines": 1
      },
      "bindable": true,
      "value": "https://pandasuite.com"
    },
    {
      "id": "errorCorrectionLevel",
      "name": "Error Correction",
      "locale_name": {
        "fr_FR": "Correction d'erreur"
      },
      "type": "Dropdown",
      "value": "M",
      "items": [
        {
          "id": "L",
          "name": "Basic",
          "locale_name": {
            "fr_FR": "Basique"
          }
        },
        {
          "id": "M",
          "name": "Standard",
          "locale_name": {
            "fr_FR": "Standard"
          }
        },
        {
          "id": "Q",
          "name": "High",
          "locale_name": {
            "fr_FR": "Élevé"
          }
        },
        {
          "id": "H",
          "name": "Maximum",
          "locale_name": {
            "fr_FR": "Maximum"
          }
        }
      ],
      "separator": true
    },
    {
      "id": "darkColor",
      "name": "Foreground Color",
      "locale_name": {
        "fr_FR": "Couleur des modules"
      },
      "type": "Color",
      "value": "#000000"
    },
    {
      "id": "lightColor",
      "name": "Background Color",
      "locale_name": {
        "fr_FR": "Couleur de fond"
      },
      "type": "Color",
      "value": "#FFFFFF"
    },
    {
      "id": "margin",
      "name": "Margin",
      "locale_name": {
        "fr_FR": "Marge"
      },
      "type": "Integer",
      "value": 4
    }
  ],

  "events": [
    {
      "id": "onGenerated",
      "name": "QR Code Generated",
      "locale_name": {
        "fr_FR": "QR Code généré"
      },
      "queryable": {
        "text": "https://pandasuite.com",
        "__desc_text": {
          "name": "Encoded text",
          "locale_name": {
            "fr_FR": "Texte encodé"
          }
        }
      }
    },
    {
      "id": "onError",
      "name": "Generation Error",
      "locale_name": {
        "fr_FR": "Erreur de génération"
      },
      "queryable": {
        "error": "Error message",
        "__desc_error": {
          "name": "Error message",
          "locale_name": {
            "fr_FR": "Message d'erreur"
          }
        }
      }
    }
  ],

  "actions": [
    {
      "id": "setText",
      "name": "Set Text",
      "locale_name": {
        "fr_FR": "Définir le texte"
      },
      "params": [
        {
          "id": "text",
          "name": "Text",
          "locale_name": {
            "fr_FR": "Texte"
          },
          "type": "String",
          "bindable": true
        }
      ]
    }
  ],

  "queryable": {
    "text": "https://pandasuite.com",
    "__desc_text": {
      "name": "Encoded text",
      "locale_name": {
        "fr_FR": "Texte encodé"
      }
    }
  }
}
